# ---- Neon PostgreSQL (recommended — free tier) ----
# 1. Sign up: https://neon.tech
# 2. Create project → copy "Connection string" (use pooled / -pooler host for production)
# 3. Paste below — Liquibase runs migrations automatically on first start
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxx-pooler.ap-southeast-1.aws.neon.tech/neondb?sslmode=require

# ---- Local PostgreSQL (alternative — comment DATABASE_URL above) ----
# DB_URL=jdbc:postgresql://localhost:5432/bizlink
# DB_USERNAME=postgres
# DB_PASSWORD=your_db_password

# JWT (min 32 chars for HS256)
JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-chars
JWT_EXPIRATION_MS=86400000

# App
SERVER_PORT=8080
UPLOAD_DIR=uploads
PUBLIC_BASE_URL=http://localhost:5173
DEV_MODE=true

# CORS — comma-separated frontend origins
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# File storage — local (free, default)
STORAGE_TYPE=local

# Subscription auto-expiry cron (default: every hour)
SUBSCRIPTION_EXPIRY_CRON=0 0 * * * *

# Razorpay (leave empty for mock payment mode in development)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# OpenAI (optional)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1
